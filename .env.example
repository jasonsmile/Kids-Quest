# Frontend dev server
FRONTEND_PORT=3000

# Backend
PORT=5000
NODE_ENV=development
DATABASE_URL=file:./dev.db

# Required for parent/child login tokens.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
JWT_SECRET=replace_with_a_long_random_secret

# Optional AI mentor config. Leave API keys empty to disable AI mentor.
AI_PROVIDER=openai

AI_OPENAI_BASE_URL=https://api.openai.com/v1
AI_OPENAI_API_KEY=
AI_OPENAI_MODEL=gpt-4o-mini

AI_VLLM_BASE_URL=
AI_VLLM_API_KEY=
AI_VLLM_MODEL=

AI_ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
AI_ANTHROPIC_API_KEY=
AI_ANTHROPIC_MODEL=claude-sonnet-4-20250514

AI_ALIYUN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_ALIYUN_API_KEY=
AI_ALIYUN_MODEL=qwen3.6-plus

AI_CHAT_RETENTION_DAYS=14
AI_CHAT_MAX_ROUNDS=20
