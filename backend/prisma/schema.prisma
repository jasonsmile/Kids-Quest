generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Parent {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String   @map("password_hash")
  email        String?
  createdAt    DateTime @default(now()) @map("created_at")
  children     Child[]

  @@map("parents")
}

model Child {
  id               String            @id @default(uuid())
  parentId         String            @map("parent_id")
  name             String
  avatarUrl        String?           @map("avatar_url")
  grade            Int
  points           Int               @default(0)
  level            Int               @default(1)
  streakDays       Int               @default(0) @map("streak_days")
  password         String
  createdAt        DateTime          @default(now()) @map("created_at")
  badges           Badge[]
  parent           Parent            @relation(fields: [parentId], references: [id], onDelete: Cascade)
  paperRecords     PaperRecord[]
  practiceConfigs  PracticeConfig[]
  practiceSessions PracticeSession[]
  chineseConfigs   ChineseConfig[]
  rewardRecords    RewardRecord[]

  @@map("children")
}

model ChineseConfig {
  id         String   @id @default(uuid())
  childId    String   @map("child_id")
  isEnabled  Boolean  @default(false) @map("is_enabled")
  dailyCount Int      @default(10) @map("daily_count")
  itemsJson  String   @default("[]") @map("items_json")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  child      Child    @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@unique([childId])
  @@map("chinese_configs")
}

model PracticeConfig {
  id             String        @id @default(uuid())
  childId        String        @map("child_id")
  dailyFrequency Int           @default(1) @map("daily_frequency")
  isEnabled      Boolean       @default(true) @map("is_enabled")
  version        Int           @default(1)
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  paperConfigs   PaperConfig[]
  child          Child         @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@map("practice_configs")
}

model PaperConfig {
  id                    String            @id @default(uuid())
  practiceConfigId      String            @map("practice_config_id")
  configName            String            @map("config_name")
  step                  Int
  formulaList           String            @map("formula_list")
  resultMinValue        Float             @map("result_min_value")
  resultMaxValue        Float             @map("result_max_value")
  numberOfFormulas      Int               @map("number_of_formulas")
  whereIsResult         Int               @default(0) @map("where_is_result")
  enableBrackets        Boolean           @default(false) @map("enable_brackets")
  carry                 Int               @default(1)
  abdication            Int               @default(1)
  remainder             Int               @default(1)
  solution              Int               @default(0)
  numberMode            String            @default("integer") @map("number_mode")
  decimalPlaces         Int?              @map("decimal_places")
  numberOfPapers        Int               @default(1) @map("number_of_papers")
  numberOfPagerColumns  Int               @default(3) @map("number_of_pager_columns")
  paperTitle            String            @default("小学生口算题") @map("paper_title")
  paperSubTitle         String            @default("姓名：__________ 日期：____月____日 时间：________ 对题：____道") @map("paper_sub_title")
  fileNameGeneratedRule String            @default("title") @map("file_name_generated_rule")
  generateMode          Int               @default(1) @map("generate_mode")
  customFormulaList     String?           @map("custom_formula_list")
  paperListData         String?           @map("paper_list_data")
  isDefault             Boolean           @default(false) @map("is_default")
  isActive              Boolean           @default(false) @map("is_active")
  createdAt             DateTime          @default(now()) @map("created_at")
  updatedAt             DateTime          @updatedAt @map("updated_at")
  practiceConfig        PracticeConfig    @relation(fields: [practiceConfigId], references: [id], onDelete: Cascade)
  practiceSessions      PracticeSession[]

  @@map("paper_configs")
}

model PracticeSession {
  id                String             @id @default(uuid())
  childId           String             @map("child_id")
  paperConfigId     String?            @map("paper_config_id")
  subject           String             @default("math")
  date              DateTime           @default(now())
  configVersion     Int                @map("config_version")
  targetCount       Int                @map("target_count")
  status            String             @default("pending")
  completedCount    Int                @default(0) @map("completed_count")
  correctCount      Int                @default(0) @map("correct_count")
  accuracy          Float?
  totalTime         Int?               @map("total_time")
  pointsEarned      Int                @default(0) @map("points_earned")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  completedAt       DateTime?          @map("completed_at")
  paperConfig       PaperConfig?       @relation(fields: [paperConfigId], references: [id])
  child             Child              @relation(fields: [childId], references: [id], onDelete: Cascade)
  questionInstances QuestionInstance[]

  @@map("practice_sessions")
}

model QuestionInstance {
  id                String            @id @default(uuid())
  practiceSessionId String            @map("practice_session_id")
  questionText      String            @map("question_text")
  correctAnswer     String            @map("correct_answer")
  questionType      String            @map("question_type")
  orderIndex        Int               @map("order_index")
  createdAt         DateTime          @default(now()) @map("created_at")
  questionAttempts  QuestionAttempt[]
  practiceSession   PracticeSession   @relation(fields: [practiceSessionId], references: [id], onDelete: Cascade)

  @@map("question_instances")
}

model QuestionAttempt {
  id                 String           @id @default(uuid())
  questionInstanceId String           @map("question_instance_id")
  userAnswer         String           @map("user_answer")
  isCorrect          Boolean          @default(false) @map("is_correct")
  timeSpent          Int?             @map("time_spent")
  submittedAt        DateTime         @default(now()) @map("submitted_at")
  questionInstance   QuestionInstance @relation(fields: [questionInstanceId], references: [id], onDelete: Cascade)

  @@map("question_attempts")
}

model RewardRecord {
  id          String   @id @default(uuid())
  childId     String   @map("child_id")
  rewardType  String   @map("reward_type")
  rewardValue String   @map("reward_value")
  reason      String
  createdAt   DateTime @default(now()) @map("created_at")
  child       Child    @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@map("reward_records")
}

model Badge {
  id        String   @id @default(uuid())
  childId   String   @map("child_id")
  badgeName String   @map("badge_name")
  badgeType String   @map("badge_type")
  earnedAt  DateTime @default(now()) @map("earned_at")
  child     Child    @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@map("badges")
}

model PaperRecord {
  id             String   @id @default(uuid())
  childId        String   @map("child_id")
  configSnapshot String   @map("config_snapshot")
  questions      String
  generatedAt    DateTime @default(now()) @map("generated_at")
  status         String   @default("pending")
  child          Child    @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@map("paper_records")
}
